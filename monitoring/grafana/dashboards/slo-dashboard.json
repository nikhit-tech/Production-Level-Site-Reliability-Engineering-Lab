{
  "title": "SLO / Error Budget",
  "uid": "ecommerce-slo",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-30d", "to": "now" },
  "tags": ["ecommerce", "sre", "slo"],
  "panels": [
    {
      "id": 1,
      "title": "30-Day Availability vs SLO Target (99.9%)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "100 * job:http_request_success_ratio:rate30d",
          "legendFormat": "Availability",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "min": 99,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99.5 },
              { "color": "green", "value": 99.9 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Remaining Error Budget (minutes this month)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "(job:http_request_success_ratio:rate30d - 0.999) / 0.001 * 43.2",
          "legendFormat": "Budget remaining (min)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 20 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3,
      "title": "Error Budget Burn Rate (1h)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{status_code=~\"5..\"}[1h]) / rate(http_requests_total[1h]) / 0.001",
          "legendFormat": "Burn rate (×)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 6 },
              { "color": "red", "value": 14.4 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line+area" } }
        }
      }
    },
    {
      "id": 4,
      "title": "Daily Error Rate (last 30 days)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "100 * rate(http_requests_total{status_code=~\"5..\"}[1d]) / rate(http_requests_total[1d])",
          "legendFormat": "Daily error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    }
  ]
}
