# Copy this file to .env and fill in real values before running locally.
# Never commit .env — it is listed in .gitignore.

# Application
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# Database — required, no default
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# JWT — required, no default; generate with: openssl rand -hex 64
JWT_SECRET=generate-a-strong-secret-here
JWT_EXPIRES_IN=24h

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Metrics (comma-separated IPs allowed to scrape /metrics)
METRICS_ALLOWED_IPS=127.0.0.1,::1

# Worker — email configuration
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ecommerce.local
INVENTORY_ALERT_EMAIL=inventory@ecommerce.local
REPORTS_EMAIL=reports@ecommerce.local

# Worker — metrics server
ENABLE_METRICS_SERVER=true
METRICS_PORT=3002
